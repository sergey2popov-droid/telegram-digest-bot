# Telegram bot token from @BotFather
BOT_TOKEN=your_bot_token_here

# Your Telegram chat ID (use /myid in the bot to find out)
CHAT_ID=123456789

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/digest

# Timezone for scheduler (IANA format)
TIMEZONE=Europe/Moscow

# How often to fetch RSS sources (minutes)
INGESTION_INTERVAL_MINUTES=30
